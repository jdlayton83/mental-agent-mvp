# Application
NODE_ENV=development
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
LOG_LEVEL=info
AUTH_SECRET=replace_with_random_auth_secret_at_least_32_chars

# Database
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/mental_agent

# AI provider
LLM_PROVIDER=openai
LLM_MODEL=replace_with_model
OPENAI_API_KEY=replace_with_real_key

# Embeddings
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=replace_with_embedding_model

# Product configuration
INITIAL_CREDIT_BALANCE=100

# Development seed
DEVELOPMENT_USER_EMAIL=dev@example.local
DEVELOPMENT_USER_PASSWORD=replace_with_local_dev_password
